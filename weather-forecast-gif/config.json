{
  "name": "Weather Forecast GIF",
  "description": "Generates an animated 64x64 weather forecast GIF from Home Assistant weather entities, designed for Divoom Pixoo 64 and similar pixel displays",
  "version": "1.5.5",
  "slug": "weather_forecast_gif",
  "url": "https://github.com/drewgourley/weather-forecast-image",
  "arch": ["armhf", "armv7", "aarch64", "amd64", "i386"],
  "init": false,
  "homeassistant_api": true,
  "ports": {
    "6942/tcp": 6942
  },
  "ports_description": {
    "6942/tcp": "Web server serving the generated GIFs"
  },
  "map": ["share:rw"],
  "options": {
    "forecast_entity": "weather.pirateweather",
    "station_entity": "",
    "radar_enabled": true,
    "radar_zoom": 6,
    "radar_color_scheme": 2,
    "radar_smooth": true,
    "radar_snow": true
  },
  "schema": {
    "forecast_entity": "str",
    "station_entity": "str?",
    "radar_enabled": "bool",
    "radar_zoom": "int(1,7)",
    "radar_color_scheme": "int(0,8)",
    "radar_smooth": "bool",
    "radar_snow": "bool"
  }
}
